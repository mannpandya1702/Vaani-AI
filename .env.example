# Vaani-AI Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit secrets.

# ─── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=                       # public — safe in frontend
SUPABASE_SERVICE_ROLE_KEY=               # SECRET — edge functions only
SUPABASE_PROJECT_REF=                    # e.g. abcdefghij
SUPABASE_ACCESS_TOKEN=                   # sbp_... for CLI

# Frontend uses these (prefixed VITE_ for vite expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Anthropic Claude (Path A: direct) ────────────────────
ANTHROPIC_API_KEY=

# ─── Anthropic Claude (Path B: via AWS Bedrock ap-south-1) ─
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# BEDROCK_MODEL_ID=

# ─── Sarvam AI (STT + TTS + Sarvam-M) ─────────────────────
SARVAM_API_KEY=

# ─── VAPI (voice orchestrator) ────────────────────────────
VAPI_API_KEY=                            # SECRET — server-side PRIVATE key
VAPI_ORG_ID=                             # vapi org uuid — needed by vapi-webhook tenant lookup
VAPI_WEBHOOK_SECRET=                     # generated locally (openssl rand -hex 32); also paste into VAPI dashboard
# Browser SDK uses these — VITE_ prefix exposes to client
VITE_VAPI_PUBLIC_KEY=                    # PUBLIC key from VAPI dashboard; DISTINCT from VAPI_API_KEY (eval/vapi-key-check.ts asserts)
VITE_VAPI_ASSISTANT_ID_HI=               # Vaani Hindi assistant uuid
VITE_VAPI_ASSISTANT_ID_TA=               # Vaani Tamil assistant uuid
# Tool ids (server-side only)
VAPI_TOOL_ID_CAPTURE_CONSENT=
VAPI_TOOL_ID_ESCALATE_TO_DOCTOR=
VAPI_TOOL_ID_TRANSFER_TO_DUTY_MO=        # legacy, retained for rollback (post-Manorama-pivot stripped from assistant toolIds)
VAPI_ASSISTANT_ID_MANORAMA=              # legacy, retained for rollback (no live traffic post-pivot)

# ─── Real RMP details (TPG ¶3.5 — fill before demo day) ──
RMP_NAME=                                # e.g. "Dr Aanya Sharma"
RMP_MCI_REG=                             # SMC + HPR-ABDM linked reg #
RMP_PHONE_E164=                          # for production-mode SIP transfer (+91...)

# ─── Frontend demo-route gate (audit D4) ──────────────────
# If unset, /cockpit and /asha are open. If set, users must land via
# ?demo=<token> or have the token in localStorage.
VITE_DEMO_TOKEN=

# ─── Webhook auth (internal Bearer for edge functions) ───
WEBHOOK_MASTER_KEY=                      # generated locally (openssl rand -hex 32)

# ─── PII redactor (deterministic session tokens) ──────────
PII_REDACTION_SEED=                      # SECRET — openssl rand -hex 32

# ─── Exotel (telephony, India) ────────────────────────────
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_VIRTUAL_NUMBER=
EXOTEL_DLT_ENTITY_ID=

# ─── Gupshup (WhatsApp Business) ──────────────────────────
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=vaaniai
GUPSHUP_SOURCE_NUMBER=
WHATSAPP_TEMPLATE_CONSENT_HI=
WHATSAPP_TEMPLATE_FOLLOWUP_HI=
WHATSAPP_TEMPLATE_DOTS_HI=
WHATSAPP_TEMPLATE_ANC_HI=

# ─── Msg91 (SMS, India) ───────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=VAANI
MSG91_DLT_TE_ID=

# ─── ABDM Sandbox ─────────────────────────────────────────
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_HFR_TOKEN=
ABDM_HPR_TOKEN=
ABDM_BASE_URL=https://dev.abdm.gov.in

# ─── Observability ────────────────────────────────────────
POSTHOG_API_KEY=
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# ─── Optional ─────────────────────────────────────────────
GOOGLE_API_KEY=                          # Gemini fallback (cheap eval)
VERCEL_TOKEN=

# ─── Internal app keys ────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_MASTER_KEY=                      # rotates webhook auth
JWT_SECRET=
PII_REDACTION_SEED=                      # for deterministic token mapping
