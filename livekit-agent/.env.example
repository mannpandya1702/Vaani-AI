# Vaani-AI LiveKit Agents voice worker — environment template.
# Copy to `.env` for local dev (`python agent.py dev`). On LiveKit Cloud /
# Render / Fly / Railway, set these as project secrets instead.
# DO NOT COMMIT a filled-in copy — real keys live in ../.env.local (gitignored).

# ─── LiveKit (the realtime media plane the worker registers with) ───────────
# wss URL of your LiveKit project (LiveKit Cloud or self-hosted).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── Vaani safety proxy (the LLM path) ──────────────────────────────────────
# The worker's LLM is livekit.plugins.openai.LLM pointed at
#   ${SUPABASE_URL}/functions/v1/vapi-custom-llm
# with WEBHOOK_MASTER_KEY as the bearer. This keeps the hardcoded statutory
# refusals + PII redaction + Claude + prompt-caching layer intact. Do NOT
# bypass it with a direct Anthropic key.
SUPABASE_URL=https://kjhpmoqybqnjpqfqitqr.supabase.co
WEBHOOK_MASTER_KEY=your_webhook_master_key

# ─── Sarvam voice stack (STT Saarika + TTS Bulbul) ──────────────────────────
SARVAM_API_KEY=your_sarvam_api_key
# TTS (Bulbul). v3 is current; speaker is a v3 voice id (gender-neutral choice
# for Vaani). For bulbul:v2 use a v2 speaker (e.g. anushka).
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=anushka
# STT (Saarika). Optional override; defaults to saarika:v2.5 in agent.py.
# SARVAM_STT_MODEL=saarika:v2.5
# TTS pace — 1.0 normal; Aanya §13 uses 0.85 on the urgent path.
# SARVAM_TTS_PACE=1.0

# ─── Deepgram (STT FALLBACK ONLY — used iff the Sarvam plugin is missing) ────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── Language ───────────────────────────────────────────────────────────────
# hi | ta. Selects the prompt file (docs/prompts/vaani-<lang>-v3.md), the
# greeting, and Sarvam's language code. NOTE: the var is read as LANG_CODE
# first, then LANG — prefer LANG_CODE to avoid clashing with the shell's $LANG.
LANG_CODE=hi

# ─── RMP identity (CLAUDE.md) — optional; placeholder डॉक्टर साहब until set ───
# RMP_NAME=
# RMP_MCI_REG=

# ─── Prompt directory override (optional) ───────────────────────────────────
# Defaults to ../docs/prompts relative to agent.py. Set when the worker is
# deployed outside the monorepo and you copy the prompt files alongside it.
# VAANI_PROMPT_DIR=/app/prompts
